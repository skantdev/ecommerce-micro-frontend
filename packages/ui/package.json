{
  "name": "@repo/ui",
  "version": "1.0.0",
  "type": "module",
  "description": "Reusable UI component library for ecommerce micro frontend",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./button": {
      "import": "./dist/components/Button.js",
      "types": "./dist/components/Button.d.ts"
    },
    "./input": {
      "import": "./dist/components/Input.js",
      "types": "./dist/components/Input.d.ts"
    },
    "./card": {
      "import": "./dist/components/Card.js",
      "types": "./dist/components/Card.d.ts"
    },
    "./modal": {
      "import": "./dist/components/Modal.js",
      "types": "./dist/components/Modal.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@repo/theme": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
